@model List<Owner>
@{
	ViewData["Title"] = "Owners";
}

<h1 class="text-black bg-green ">Owners</h1>
<a asp-action="Create" class="btn btn-secondary">Add an Owner</a>
<br /><br /><br />
<table class="table table-sm table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Surname</th>
        <th>Date Of Birth</th>
        <th>His Cars</th>
        <th>Update</th>
        <th>Delete</th>
    </tr>
    @foreach (Owner o in Model)
    {
        <tr>
            <td>@o.Id</td>
            <td>@o.Name</td>
            <td>@o.Surname</td>
            <td>@o.DateOfBirth.Date.ToString("d")</td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="OwnerCars" asp-route-id="@o.Id">
                    His cars
                </a>
            </td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="Update" asp-route-id="@o.Id">
                    Update
                </a>
            </td>
            <td>
                <form asp-action="Delete" asp-route-id="@o.Id" method="post">
                    <button type="submit" class="btn btn-sm btn-danger">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
</table>


@Html.Partial("PageLink")
<br /><br /><br />

<div carek></div>