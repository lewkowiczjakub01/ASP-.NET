@model List<Car>
@{
	ViewData["Title"] = "Cars";
}

 
<h1 class="text-black bg-green">Cars</h1>
<a asp-action="Create" class="btn btn-secondary">Add a Car</a>
<br /><br /><br />
<table class="table table-sm table-bordered">
    <tr>
        <th>Id</th>
        <th>Owner</th>
        <th>Mark</th>
        <th>Model</th>
        <th>Year of Production</th>
        <th>Plate</th>
        <th>Update</th>
        <th>Delete</th>
    </tr>
    @foreach (Car c in Model)
    {
        <tr>
            <td>@c.Id</td>
            <td>@c.Owner_R?.Name @c.Owner_R?.Surname</td>
            <td>@c.Mark</td>
            <td>@c.Model</td>
            <td>@c.YearOfProduction</td>
            <td>@c.Plate</td>
            <td>
                <a class="btn btn-sm btn-primary" asp-action="Update" asp-route-id="@c.Id">
                    Update
                </a>
            </td>
            <td>
                <form asp-action="Delete" asp-route-id="@c.Id" method="post">
                    <button type="submit" class="btn btn-sm btn-danger">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
</table>
@Html.Partial("PageLink")